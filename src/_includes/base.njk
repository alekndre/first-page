<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Stardos+Stencil:wght@400;500;600;700&family=IBM+Plex+Sans:wght@400;500&display=swap" rel="stylesheet">
    <meta name="format-detection" content="telephone=no">
    <script>
      document.documentElement.dataset.theme = localStorage.getItem('theme') || 'dark';
    </script>
    {% if description %}<meta name="description" content="{{ description }}">{% endif %}
    <link rel="stylesheet" href="css/colors.css">
    <link rel="stylesheet" href="css/base.css">
    <link rel="stylesheet" href="css/navbar.css">
    <link rel="stylesheet" href="css/zones.css">
    <link rel="stylesheet" href="css/marquee.css">
    {% for style in pageStyles %}<link rel="stylesheet" href="css/{{ style }}.css">
    {% endfor %}
  </head>

  <body>
    {% if isHome %}
    <nav class="dot-nav" data-i18n-aria="dots_nav" aria-label="Sekcje strony">
      <a href="#top" class="dot" data-i18n-aria="nav_home" aria-label="Strona główna"></a>
      <a href="#zone-about" class="dot" data-i18n-aria="nav_about" aria-label="O firmie"></a>
      <a href="#zone-services" class="dot" data-i18n-aria="nav_services" aria-label="Usługi"></a>
      <a href="#zone-projects" class="dot" data-i18n-aria="nav_projects" aria-label="Projekty"></a>
    </nav>
    {% endif %}

    <header class="navbar">
      <a href="index.html" class="logo">
        <img src="img/logo/logo_ms-dark.png" alt="MontechSerwis" class="logo-img">
      </a>

      <nav class="nav-links">
        <a href="o-nas.html" data-i18n="nav_about">O firmie</a>
        <a href="uslugi.html" data-i18n="nav_services">Usługi</a>
        <a href="projekty.html" data-i18n="nav_projects">Projekty</a>
        <a href="certyfikaty.html" data-i18n="nav_certificate">Certyfikaty</a>
        <a href="galeria.html" data-i18n="nav_gallery">Galeria</a>
        <a href="kontakt.html" data-i18n="nav_contact">Kontakt</a>
      </nav>

      <div class="navbar-actions">
        <div class="lang-switch">
          <button class="lang-btn active" data-lang="pl">PL</button>
          <span class="lang-divider">|</span>
          <button class="lang-btn" data-lang="en">EN</button>
        </div>

        <button class="theme-toggle" aria-label="Przełącz motyw">
          <svg class="icon-sun" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2" stroke-linecap="round">
            <circle cx="12" cy="12" r="4"/>
            <path d="M12 2v2.5M12 19.5V22M2 12h2.5M19.5 12H22
                    M4.9 4.9l1.8 1.8M17.3 17.3l1.8 1.8M19.1 4.9l-1.8 1.8M6.7 17.3l-1.8 1.8"/>
          </svg>
          <svg class="icon-moon" viewBox="0 0 24 24" fill="currentColor">
            <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/>
          </svg>
        </button>

        <button class="hamburger" aria-label="Otwórz menu">☰</button>
      </div>

      <div class="scroll-progress" aria-hidden="true"></div>
    </header>

    {{ content | safe }}

    <footer class="footer">
      <div class="footer-grid">
        <div>
          <p class="footer-brand">Montech Serwis</p>
          <p class="footer-desc" data-i18n="footer_desc">Montaż i serwis instalacji okrętowych.</p>
          <br>
          <p class="contact-dept-label">NIP: 9580672783</p>
          <p class="contact-dept-label">REGON: 220213079</p>
        </div>
        <address class="footer-contact">
          <p class="footer-brand" data-i18n="nav_contact">Kontakt</p>
          <div class="contact-split">
            <div class="contact-dept">
              <p class="contact-dept-label" data-i18n="contact_office">Biuro</p>
              <a href="mailto:office@montechserwis.com">office@montechserwis.com</a>
              <a href="tel:+48698125290">+48 698 125 290</a>
            </div>
            <div class="contact-dept">
              <p class="contact-dept-label" data-i18n="contact_service">Serwis</p>
              <a href="mailto:montechserwis@gmail.com">montechserwis@gmail.com</a>
              <a href="tel:+48500601240">+48 500 601 240</a>
            </div>
          </div>
          <div class="contact-address">
            <p class="contact-dept-label" data-i18n="contact_address">Adres</p>
            <a href="https://maps.app.goo.gl/WaFb8BMX5vGgM9K17"
              target="_blank"
              rel="noopener noreferrer">
              <span>Aleja Grunwaldzka 487c,<br></span>
              <span>80-309 Gdańsk,<br></span>
              <span data-i18n="contact_country">Polska</span>
            </a>
          </div>
        </address>
        <nav class="footer-nav" aria-label="Nawigacja w stopce">
          <p class="footer-brand">Menu</p>
          <a href="o-nas.html" data-i18n="nav_about">O firmie</a>
          <a href="uslugi.html" data-i18n="nav_services">Usługi</a>
          <a href="projekty.html" data-i18n="nav_projects">Projekty</a>
          <a href="certyfikaty.html" data-i18n="nav_certificate">Certyfikaty</a>
          <a href="galeria.html" data-i18n="nav_gallery">Galeria</a>
          <a href="kontakt.html" data-i18n="nav_contact">Kontakt</a>
        </nav>
      </div>
      <p class="footer-bottom">© 2026 Montech Serwis</p>
    </footer>

    <script src="js/translations.js"></script>
    <script src="js/script.js"></script>
  </body>
</html>